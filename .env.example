# ============================================================
# 海康威视密码重置工具 - 环境变量配置
# Hikvision Password Reset Tool - Environment Variables
# ============================================================
# 复制此文件为 .env 并按需修改 / Copy this file to .env and modify as needed

# 后端服务监听地址 / Backend bind host
HOST=0.0.0.0

# 后端服务端口 / Backend port
PORT=8000

# 日志级别: debug / info / warning / error / critical
# Log level: debug / info / warning / error / critical
LOG_LEVEL=info

# CORS 允许的前端地址，多个地址用逗号分隔
# CORS allowed origins, comma-separated for multiple values
# 生产环境请改为具体地址，例如: http://192.168.1.100:5173
# In production, specify the exact address, e.g.: http://192.168.1.100:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# 前端开发服务端口 / Frontend dev server port
FRONTEND_PORT=5173
